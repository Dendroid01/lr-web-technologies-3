@use 'variables' as *;
@use 'mixins' as *;
@use 'sass:color';

.guestbook-list {
    margin-top: $spacing-xl;

    h2 {
        position: relative;
        display: inline-block;
        margin-bottom: $spacing-lg;
        font-size: 28px;
        font-weight: 600;
        color: $color-text;

        &::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 3px;
            background: $color-accent;
            border-radius: 3px;
        }
    }
}

.guestbook-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: $color-white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    font-size: 0.95rem;

    thead {
        tr {
            background: linear-gradient(135deg, $color-accent 0%, color.scale($color-accent, $lightness: -8%) 100%);
        }

        th {
            padding: 16px 20px;
            text-align: left;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: $color-white;
            border-bottom: none;

            &:first-child {
                border-top-left-radius: 20px;
            }

            &:last-child {
                border-top-right-radius: 20px;
            }
        }
    }

    tbody {
        tr {
