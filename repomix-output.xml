@use 'variables' as *;

.birthdate-container {
  position: relative;
  margin-bottom: $spacing-md;
}

.calendar {
  position: absolute;
  top: 100%;
  left: 0;
  width: 300px;
  background: $color-white;
  border: 2px solid $border-color;
  border-radius: $border-radius;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  z-index: 1000;
  display: none;
  padding: 15px;

  &.active {
    display: block;
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #e0e0e0;
  }

  .calendar-selects {
    display: flex;
    gap: 10px;
    margin-bottom: 15px;

    select {
      flex: 1;
      padding: 8px;
      border: 1px solid #d2b48c;
      border-radius: 4px;
      background: $color-white;
    }
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 5px;
    margin-bottom: 10px;

    .calendar-weekday {
      text-align: center;
      font-weight: $font-weight-bold;
      font-size: $font-size-sm;
      padding: 5px;
      color: $color-text;
    }

    .calendar-day {
      text-align: center;
      padding: 8px;
      border: 1px solid transparent;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: $font-size-sm;

      &:hover {
        background-color: $color-accent;
        color: $color-white;
      }

      &.other-month {
        color: #ccc;
        cursor: default;

        &:hover {
          background-color: transparent;
          color: #ccc;
        }
      }

      &.selected {
        background-color: $color-accent;
        color: $color-white;
        border-color: $color-accent;
      }

      &.today {
        border-color: $color-accent;
        font-weight: $font-weight-bold;
      }
    }
  }

  .calendar-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #e0e0e0;

    .calendar-btn {
      padding: 5px 10px;
      border: 1px solid #d2b48c;
      border-radius: 4px;
      background: #d2b48c;
      cursor: pointer;
      transition: all 0.2s;

      &.primary {
        background: $color-accent;
        color: $color-white;
        border-color: $color-accent;

        &:hover {
          background: #004494;
        }
      }

      &:hover {
        background: #f5f5f5;
      }
    }
  }
}
</file>

<file path="src/resources/css/2.0/scss/_dropdown.scss">
.sidebar {
    position: relative;

    .dropdown {
        position: relative;

        .dropdown-arrow {
            margin-left: auto;
            font-size: 0.7rem;
            transition: transform 0.3s ease;
        }

        // Дропдаун меню - появляется СПРАВА от кнопки
        .dropdown-menu {
            position: fixed;
            left: 100%; // Появляется справа от сайдбара
            top: 0;
            min-width: 200px;
            background: linear-gradient(135deg, #1e2a3a 0%, #0f172a 100%);
            border-radius: 12px;
            padding: 8px 0;
            margin: 0;
            list-style: none;
            opacity: 0;
            visibility: hidden;
            transform: translateX(-10px);
            transition: all 0.3s ease;
            z-index: 1000;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);

            &.active {
                opacity: 1;
                visibility: visible;
                transform: translateX(0);
            }

            li {
                margin: 0;

                a {
                    display: block;
                    padding: 10px 20px;
                    color: #e2e8f0;
                    text-decoration: none;
                    font-size: 0.875rem;
                    transition: all 0.2s ease;
                    white-space: nowrap;

                    &:hover {
                        background: rgba(255, 255, 255, 0.1);
                        padding-left: 25px;
                        color: #60a5fa;
                    }

                    &.active {
                        background: linear-gradient(90deg, rgba(96, 165, 250, 0.15), transparent);
                        color: #60a5fa;
                        border-left: 3px solid #60a5fa;
                    }
                }
            }
        }
    }
}
</file>

<file path="src/resources/css/2.0/scss/_form-popover.scss">
.form-popover {
  position: absolute;
  z-index: 9999;
  display: inline-block;
  background: #333;
  color: #fff;
  font-size: 0.9rem;
  line-height: 1.4;
  padding: 8px 12px;
  border-radius: 8px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  max-width: 260px;
  pointer-events: none;
  white-space: normal;

  &.show {
    opacity: 1;
  }

  &:after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    margin-left: -5px;
    border-width: 5px;
    border-style: solid;
    border-color: #333 transparent transparent transparent;
  }

  &[data-popover]:focus,
  &[data-popover]:hover {
    outline: 2px solid #4a90e2;
    outline-offset: 2px;
  }
}
</file>

