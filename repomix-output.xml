            padding: 12px 24px;
            font-size: 16px;
            font-weight: $font-weight-bold;
            color: $color-white;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
            border-radius: 10px;

            &[type="submit"] {
                background-color: #5a3e36;
                flex: 2;

                &:hover {
                    background-color: #7a5544;
                    transform: translateY(-2px);
                }

                &:active {
                    transform: translateY(0);
                }

                &:disabled {
                    background-color: #cccccc !important;
                    cursor: not-allowed;
                    opacity: 0.6;

                    &:hover {
                        background-color: #cccccc !important;
                        transform: none;
                    }
                }
            }

            &[type="reset"] {
                background-color: #d2b48c;
                color: #5a3e36;
                flex: 1;

                &:hover {
                    background-color: #c19f7d;
                    transform: translateY(-2px);
                }

                &:active {
                    transform: translateY(0);
                }
            }
        }
    }

    .alert {
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: $spacing-md;
        font-size: 14px;

        &.alert-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        &.alert-error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
    }

    .error {
        color: $color-error;
        font-size: $font-size-sm;
        margin-top: 5px;
        display: block;
    }
}

.back-link-wrapper {
    margin-top: $spacing-lg;
    padding-top: $spacing-md;
    border-top: 1px solid rgba(90, 62, 54, 0.2);
    text-align: center;

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background-color: transparent;
        color: #5a3e36;
        text-decoration: none;
        font-weight: $font-weight-bold;
        font-size: 15px;
        border-radius: 8px;
        transition: all 0.3s;

        &:hover {
            background-color: rgba(90, 62, 54, 0.1);
            transform: translateX(-3px);
        }

        &:active {
            transform: translateX(0);
        }

        &::before {
            content: "←";
            font-size: 18px;
            transition: transform 0.3s;
        }

        &:hover::before {
            transform: translateX(-3px);
        }
    }
}
