<file path="src/resources/css/2.0/scss/_blog.scss">
@use 'variables' as *;
@use 'mixins' as *;

// Стили для блога
.blog-posts {
    margin-top: $spacing-xl;

    h2 {
        position: relative;
        display: inline-block;
        margin-bottom: $spacing-lg;
        font-size: 28px;
        font-weight: 600;
        color: $color-text;

        &::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 3px;
            background: $color-accent;
            border-radius: 3px;
        }
    }
}

.blog-post {
    background: $color-white;
    border-radius: 20px;
    padding: $spacing-lg;
    margin-bottom: $spacing-lg;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;

    &:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
    }

    h2 {
        margin: 0 0 $spacing-sm 0;
        font-size: 24px;
        color: $color-accent;

        &::after {
            display: none;
        }
    }

    .blog-meta {
        color: #718096;
        font-size: $font-size-sm;
        margin-bottom: $spacing-md;
        padding-bottom: $spacing-sm;
        border-bottom: 1px solid #edf2f7;
    }

    .blog-image {
        max-width: 400px;
        margin: $spacing-md 0;
        border-radius: 12px;
        overflow: hidden;

        img {
            width: 100%;
            height: auto;
            object-fit: cover;
        }
    }

    .blog-message {
        line-height: 1.6;
        color: #2d3748;
        font-size: 1rem;
    }
}

.blog-editor-form {
    max-width: 800px;
    margin: 30px auto;
    padding: $spacing-xl;
    background-color: #f5e6d0;
    border-radius: $border-radius;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);

    form {
        display: flex;
        flex-direction: column;
        gap: $spacing-md;
    }

    label {
        font-weight: $font-weight-bold;
        color: #5a3e36;
    }

    input, textarea, select {
        padding: 10px 15px;
        font-size: 16px;
        border: 2px solid #d2b48c;
        border-radius: 8px;
        outline: none;
        transition: border-color 0.3s, box-shadow 0.3s;

        &:focus {
            border-color: #a67c52;
            box-shadow: 0 0 5px rgba(166, 124, 82, 0.5);
        }
    }

    textarea {
        resize: vertical;
        font-family: inherit;
    }

    button {
        padding: 12px 20px;
        font-size: 16px;
        font-weight: $font-weight-bold;
        color: $color-white;
        background-color: #5a3e36;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.3s;

        &:hover {
            background-color: #7a5544;
            transform: translateY(-2px);
        }

        &:active {
            transform: translateY(0);
        }
    }

    .error {
        color: $color-error;
        font-size: $font-size-sm;
        margin-top: 5px;
        display: block;
    }
}

.blog-preview-list {
    margin-top: $spacing-xl;
    padding-top: $spacing-lg;
    border-top: 2px solid $border-color;

    h3 {
        margin-bottom: $spacing-md;
        font-size: 22px;
        font-weight: $font-weight-bold;
        color: $color-text;
    }
}

.blog-post-preview {
    padding: $spacing-md;
    border-bottom: 1px solid #e2e8f0;
    transition: background 0.2s ease;

    &:hover {
        background: #f8fafc;
    }

    strong {
        color: $color-accent;
    }

    em {
        color: #718096;
        font-style: normal;
        font-size: $font-size-sm;
    }
}

.blog-pagination {
    margin-top: $spacing-xl;
    display: flex;
    justify-content: center;

    nav {
        display: flex;
        gap: $spacing-sm;
    }

    .pagination-link {
        padding: 8px 12px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: $color-text;
        text-decoration: none;
        transition: all 0.2s;

        &:hover {
            background: $color-accent;
            color: $color-white;
            border-color: $color-accent;
        }

        &.active {
            background: $color-accent;
            color: $color-white;
            border-color: $color-accent;
        }
    }
}

.alert {
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: $spacing-md;

    &.alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    &.alert-error {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
}
</file>

