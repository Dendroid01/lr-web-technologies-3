    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    animation: fadeIn 0.3s ease;

    @media (max-width: 768px) {
        width: 90%;
        margin: 10% auto;
        padding: $spacing-lg;
    }
}

.blur-modal-close {
    color: #aaa;
    float: right;
    font-size: 28px;
    font-weight: $font-weight-bold;
    cursor: pointer;
    line-height: 1;
    margin-top: -10px;
    @include transition(color);

    &:hover {
        color: $color-black;
    }
}

.blur-modal-body {
    margin-top: $spacing-lg;
    padding: $spacing-sm 0;
    clear: both;

