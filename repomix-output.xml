<file path="src/resources/css/2.0/scss/_modal.scss">
@use 'variables' as *;
@use 'mixins' as *;
@use 'sass:color';

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    @include transition(opacity);
    animation: fadeIn 0.3s ease;

    &.show {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        position: relative;
        width: min(92vw, 1000px);
        height: min(90vh, 760px);
        background: $color-white;
        border-radius: $border-radius;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding: 24px 24px 20px;
        animation: scaleIn 0.3s ease;

        .modal-image-container,
        .modal-image {
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1 1 auto;
            min-height: 0;
            border-radius: 12px;
            background-color: #f5f7fa;
            border: 1px solid #e3e9f1;
            overflow: hidden;
        }

        .modal-image-container {
            padding: 14px;
        }

        .modal-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s ease;

            &.original-size {
                max-width: none;
                max-height: none;
            }

            &.loading {
                opacity: 0.5;
                background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
                background-size: 200% 100%;
                animation: loading 1.5s infinite;
            }

            &:hover {
                transform: scale(1.01);
            }
        }

        .modal-info {
            padding: 16px 18px;
            background: $color-white;
            border-top: 2px solid $border-color;
            text-align: center;
            flex-shrink: 0;

            .modal-title {
                margin: 0 0 10px 0;
                font-size: 24px;
                color: $color-text;
                font-weight: $font-weight-bold;
            }

            .modal-description {
                margin: 0 0 15px 0;
                font-size: 16px;
                color: $color-text;
                line-height: 1.5;
                max-width: 600px;
                margin-left: auto;
                margin-right: auto;
            }

            .modal-counter {
                font-size: 14px;
                color: #666;
                font-weight: $font-weight-bold;
            }
        }

        .modal-close {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 40px;
            height: 40px;
            background: rgba(0, 0, 0, 0.7);
            border-radius: 50%;
            cursor: pointer;
            z-index: 1001;
            @include flex-center(row, center, center);
            font-size: 28px;
            font-weight: bold;
            color: $color-white;
            transition: all 0.3s ease;

            &:hover {
                background: rgba(0, 0, 0, 0.9);
                transform: scale(1.1);
            }
        }

        .modal-nav {
            position: absolute;
            top: calc(50% - 40px);
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            padding: 0 12px;
            transform: translateY(-50%);
            z-index: 1001;

            .nav-btn {
                background: rgba(0, 0, 0, 0.7);
                color: $color-white;
                border: none;
                width: 50px;
                height: 50px;
                border-radius: 50%;
                font-size: 20px;
                cursor: pointer;
                @include flex-center(row, center, center);
                transition: all 0.3s ease;
                pointer-events: auto;

                &:hover {
                    background: rgba(0, 0, 0, 0.9);
                    transform: scale(1.1);
                }

                &:disabled {
                    opacity: 0.3;
                    cursor: not-allowed;
                    transform: none;
                }
            }
        }
    }
}

.modal-trigger {
    background-color: $color-accent;
    color: $color-white;
    border: none;
    padding: 10px 20px;
    border-radius: 5px;
    cursor: pointer;
    font-size: 14px;
    margin: 10px 0;
    @include transition(background-color);

    &:hover {
        background-color: color.adjust($color-accent, $lightness: -10%);
    }
}

.blur-modal {
    display: none;
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    backdrop-filter: blur(5px);
    background-color: rgba(0, 0, 0, 0.6);

    &.show {
        display: block;
    }
}

.blur-modal-content {
    background-color: $color-white;
    margin: 5% auto;
    padding: $spacing-xl;
    border-radius: $border-radius;
    width: 80%;
    max-width: 600px;
    max-height: 80vh;
    overflow-y: auto;
